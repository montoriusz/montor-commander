{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/config.schema.json",
  "app": {
    "security": {
      "csp": "default-src 'self'"
    },
    "windows": [
      {
        "decorations": true,
        "fullscreen": false,
        "height": 600,
        "resizable": true,
        "title": "tauri-terminal",
        "width": 800
      }
    ],
    "withGlobalTauri": true
  },
  "build": {
    "beforeBuildCommand": "pnpm build",
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all"
  },
  "identifier": "com.tauri-terminal.dev",
  "plugins": {
    "typegen": {
      "excludePatterns": null,
      "force": true,
      "includePatterns": null,
      "includePrivate": true,
      "projectPath": "./src-tauri",
      "outputPath": "./src/generated",
      "typeMappings": null,
      "validationLibrary": "none",
      "verbose": true,
      "visualizeDeps": false
    }
  },
  "productName": "tauri-terminal",
  "version": "0.0.0"
}
