{
  // Root tsconfig file using project references
  // This approach provides better performance and organization
  "files": [],
  "references": [
    // Configuration for application source code (src/)
    { "path": "./tsconfig.app.json" },
    // Configuration for Node.js files (vite.config.ts, etc.)
    { "path": "./tsconfig.node.json" },
  ],

  "compilerOptions": {
    "baseUrl": "./",

    "paths": {
      "@/*": ["./src/*"],
    },
  },
}
